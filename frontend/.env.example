# AWS Region
VITE_AWS_REGION="us-east-1"

# Amazon Bedrock AgentCore Runtime ARN
# Get this from CDK deployment output (AgentCoreStack.RuntimeArn)
VITE_AGENTCORE_RUNTIME_ARN="arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/healthcare-voice-agent"

# Amazon Cognito User Pool Configuration
# Get these from CDK deployment output
VITE_COGNITO_USER_POOL_ID="us-east-1_XXXXXXXXX"
VITE_COGNITO_USER_POOL_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxx"
VITE_COGNITO_IDENTITY_POOL_ID="us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# DynamoDB Table Names
VITE_PATIENTS_TABLE="nova-healthcare-patients"

# Application Configuration
VITE_APP_NAME="Healthcare Voice Assistant"
VITE_DEPLOYMENT_TYPE="local"
